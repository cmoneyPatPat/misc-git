view: zendesk_sla_time_to_reply_calendar {
  derived_table: {
    sql: WITH SLA AS (
            SELECT
                    ticket_metrics.ticket_id  AS "ticket_id",
                    ticket_metrics.created_at AS "created_time",
                    "group".name  AS "group",
                    ticket_metrics.initially_assigned_at AS "initially_assigned_time",
                    ticket.status as "status",
                    case "group".name
                        WHEN 'Accounts' THEN '720'
                        WHEN 'Advanced Accounts' THEN '720'
                        WHEN 'Advanced Account Maintenance' THEN '720'
                        WHEN 'ACAT' THEN '720'
                        WHEN 'Onboarding' THEN '720'
                        WHEN 'Usability' THEN '720'
                        WHEN 'Account Maintenance' THEN '720'
                        WHEN 'Document Request and Taxes' THEN '720'
                        WHEN 'Banking 2.0' THEN '720'
                        WHEN 'ACAT' THEN '720'
                        WHEN 'Cash Management' THEN '720'
                        WHEN 'Conversion Escalations' THEN '720'
                        WHEN 'Social' THEN '720'
                        WHEN 'Crypto Tier 1' THEN '720'
                        WHEN 'Crypto Tier 2' THEN '720'
                        WHEN 'Equities Tier 1' THEN '720'
                        WHEN 'Equities Tier 2' THEN '720'
                        WHEN 'Options Tier 1' THEN '720'
                        WHEN 'Options Tier 2' THEN '720'
                        WHEN 'Customer Facing Risk and Recovery' THEN '720'
                        WHEN 'Legal' THEN '720'
                        WHEN 'Security' THEN '720'
                        WHEN 'Regulatory and Government Engagement' THEN '720'
                        WHEN 'White Glove' THEN '720'
                        else '720' end  AS "sla_reply_time_in_minutes_calendar"
                    FROM zendesk.ticket  AS ticket
                    LEFT JOIN zendesk."group"  AS "group" ON ticket.group_id = ("group".id)
                    LEFT JOIN zendesk.ticket_metrics  AS ticket_metrics ON ticket.id = ticket_metrics.ticket_id
                    GROUP BY 1,2,3,4,5
            )

            SELECT
            ticket_id,
            created_time,
            "group",
            initially_assigned_time,
            sla_reply_time_in_minutes_calendar,
            CASE
              WHEN (datediff(minute, created_time, getdate()) >=  sla_reply_time_in_minutes_calendar)
                    AND ( initially_assigned_time IS NULL )
                    AND  ((status  NOT IN ('pending', 'solved', 'closed') OR status IS NULL))
                    THEN 1
              ELSE 0
            END AS "is_backlog",
            CASE
              WHEN (datediff(minute, created_time, getdate()) >=  (sla_reply_time_in_minutes_calendar -240 ) )
                    AND (datediff(minute, created_time, getdate()) < sla_reply_time_in_minutes_calendar)
                    AND ( initially_assigned_time IS NULL )
                    AND  ((status  NOT IN ('pending', 'solved', 'closed') OR status IS NULL))
                    THEN 1
              ELSE 0
            END AS "is_within_4_hours_to_sla_breach",
            CASE
              WHEN (datediff(minute, created_time, getdate()) >=  (sla_reply_time_in_minutes_calendar -120 ) )
                    AND (datediff(minute, created_time, getdate()) < sla_reply_time_in_minutes_calendar)
                    AND ( initially_assigned_time IS NULL )
                    AND  ((status  NOT IN ('pending', 'solved', 'closed') OR status IS NULL))
                    THEN 1
              ELSE 0
            END AS "is_within_2_hours_to_sla_breach"
            CASE
              WHEN (datediff(minute, created_time, getdate()) >=  (sla_reply_time_in_minutes_calendar) )
                    AND (datediff(minute, created_time, getdate()) < sla_reply_time_in_minutes_calendar)
                    AND ( initially_assigned_time IS NULL )
                    AND  ((status  NOT IN ('pending', 'solved', 'closed') OR status IS NULL))
                    THEN 1
              ELSE 0
            END AS "is_breached"
            FROM SLA
            WHERE created_time IS NOT NULL
             ;;
  }

  measure: count {
    type: count
    drill_fields: [detail*]
  }

  dimension: ticket_id {
    type: number
    sql: ${TABLE}.ticket_id ;;
  }

  dimension_group: created_time {
    type: time
    sql: ${TABLE}.created_time ;;
  }

  dimension: group {
    type: string
    sql: ${TABLE}."group" ;;
  }

  dimension_group: initially_assigned_time {
    type: time
    sql: ${TABLE}.initially_assigned_time ;;
  }

  dimension: sla_reply_time_in_minutes_calendar {
    type: string
    sql: ${TABLE}.sla_reply_time_in_minutes_calendar ;;
  }

  dimension: is_backlog {
    type: number
    sql: ${TABLE}.is_backlog ;;
  }

  dimension: is_within_4_hours_to_sla_breach {
    type: number
    sql: ${TABLE}.is_within_4_hours_to_sla_breach ;;
  }
  
  dimension: is_within_2_hours_to_sla_breach {
    type: number
    sql: ${TABLE}.is_within_2_hours_to_sla_breach ;;
  }

  measure: count_backlog{
    type: sum
    sql: ${TABLE}.is_backlog ;;
  }

  measure: count_within_4_hours_to_sla_breach{
    type: sum
    sql: ${TABLE}.is_within_4_hours_to_sla_breach ;;
  }
  
  measure: count_within_2_hours_to_sla_breach{
    type: sum
    sql: ${TABLE}.is_within_2_hours_to_sla_breach ;;
  }
  
  measure: is_breached{
    type: sum
    sql: ${TABLE}.is_breached ;;
  }

  set: detail {
    fields: [
      ticket_id,
      created_time_time,
      group,
      initially_assigned_time_time,
      sla_reply_time_in_minutes_calendar,
      is_backlog
    ]
  }
}
